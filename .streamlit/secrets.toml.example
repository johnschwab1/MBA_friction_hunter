# MBA Friction Hunter — Streamlit Secrets
#
# For local dev:  copy to .streamlit/secrets.toml and fill in values
# For Streamlit Cloud: paste each key/value into the Secrets dashboard
# For Google Cloud Run (Berkeley): set these as environment variables
#
# Only one provider needs to be configured at a time.
# Flip LLM_PROVIDER to switch without changing any other code.

# ── Provider selection ──
LLM_PROVIDER = "anthropic"    # "anthropic" | "gemini"

# ── Anthropic (default) ──
ANTHROPIC_API_KEY = "sk-ant-..."
ANTHROPIC_MODEL   = "claude-opus-4-8"    # claude-sonnet-4-6 for lower cost

# ── Gemini (UC Berkeley enterprise or personal AI Studio key) ──
# Leave GEMINI_API_KEY blank if using Application Default Credentials on GCP
GEMINI_API_KEY = ""
GEMINI_MODEL   = "gemini-2.0-flash"      # gemini-2.0-pro for higher quality
